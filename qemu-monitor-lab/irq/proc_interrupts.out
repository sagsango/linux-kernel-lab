# How many times did Linux actually run an interrupt handler on CPU X for IRQ N?
# NOTE: These count will be less than the, info irq number

ubuntu@ubuntu-lkp:/sys$ cat /proc/interrupts
           CPU0       CPU1
  0:        145          0   IO-APIC   2-edge      timer
  1:          0          9   IO-APIC   1-edge      i8042
  4:          0        772   IO-APIC   4-edge      ttyS0
  8:          1          0   IO-APIC   8-edge      rtc0
  9:          0          0   IO-APIC   9-fasteoi   acpi
 11:      27405          0   IO-APIC  11-fasteoi   ens3
 12:        125          0   IO-APIC  12-edge      i8042
 14:       9520          0   IO-APIC  14-edge      ata_piix
 15:          0       2620   IO-APIC  15-edge      ata_piix
NMI:          0          0   Non-maskable interrupts
LOC:      23223      24156   Local timer interrupts
SPU:          0          0   Spurious interrupts
PMI:          0          0   Performance monitoring interrupts
IWI:          2          3   IRQ work interrupts
RTR:          0          0   APIC ICR read retries
RES:       1830       2142   Rescheduling interrupts
CAL:       7031      17546   Function call interrupts
TLB:         26         21   TLB shootdowns
TRM:          0          0   Thermal event interrupts
THR:          0          0   Threshold APIC interrupts
DFR:          0          0   Deferred Error APIC interrupts
MCE:          0          0   Machine check exceptions
MCP:          8          8   Machine check polls
ERR:          0
MIS:          0
PIN:          0          0   Posted-interrupt notification event
NPI:          0          0   Nested posted-interrupt event
PIW:          0          0   Posted-interrupt wakeup event
